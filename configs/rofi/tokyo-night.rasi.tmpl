configuration {
    sort: true;
    sorting-method: "normal";
}

* {
    bg:       ${BG_HEX};
    bg-alt:   ${BG_ALT_HEX};
    fg:       ${FG_HEX};
    fg-dim:   ${FG_DIM_HEX};
    accent:   ${ACCENT_HEX};
    urgent:   ${URGENT_HEX};
    border:   ${BORDER_HEX};

    background-color: transparent;
    text-color:       @fg;
    font:             "${FONT_NAME} ${FONT_SIZE}";
}

window {
    background-color: @bg;
    border:           2px;
    border-color:     @accent;
    border-radius:    6px;
    padding:          16px;
    width:            520px;
    location:         center;
}

mainbox {
    children: [ inputbar, listview ];
    spacing:  12px;
}

inputbar {
    background-color: @bg-alt;
    border-radius:    4px;
    padding:          8px 12px;
    children:         [ prompt, entry ];
    spacing:          8px;
}

prompt {
    text-color: @accent;
}

entry {
    placeholder:       "Search…";
    placeholder-color: @fg-dim;
}

listview {
    lines:         8;
    columns:       1;
    cycle:         true;
    dynamic:       true;
    scrollbar:     false;
    spacing:       4px;
    fixed-height:  false;
}

element {
    padding:       6px 10px;
    border-radius: 4px;
    spacing:       10px;
}

element selected {
    background-color: @accent;
    text-color:       @bg;
}

element-icon {
    size:             1.2em;
    background-color: transparent;
    vertical-align:   0.5;
}

element-text {
    text-color:       inherit;
    background-color: transparent;
    vertical-align:   0.5;
}
