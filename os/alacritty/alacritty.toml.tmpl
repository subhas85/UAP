[env]
TERM = "xterm-256color"

[window]
opacity = 1.0
padding = { x = 8, y = 8 }
dynamic_padding = false
decorations = "none"

[scrolling]
history = 10000

[font]
normal = { family = "${FONT_NAME}", style = "Regular" }
bold   = { family = "${FONT_NAME}", style = "Bold" }
italic = { family = "${FONT_NAME}", style = "Italic" }
size = ${FONT_SIZE}.0
builtin_box_drawing = false

[cursor]
style = { shape = "Block", blinking = "Off" }
unfocused_hollow = true
thickness = 0.15

[mouse]
hide_when_typing = true

# Theme palette (rendered from identity.theme)
[colors.primary]
background = "${BG_HEX}"
foreground = "${FG_HEX}"

# ANSI 16-colour palette: left as Tokyo Night defaults.
# For other palettes, override this file with assets/alacritty-ansi.toml in uap.local.
[colors.normal]
black   = "${BORDER_HEX}"
red     = "${URGENT_HEX}"
green   = "${GREEN_HEX}"
yellow  = "${YELLOW_HEX}"
blue    = "${ACCENT_HEX}"
magenta = "${PURPLE_HEX}"
cyan    = "#449dab"
white   = "${FG_DIM_HEX}"

[colors.bright]
black   = "${INACTIVE_HEX}"
red     = "#ff7a93"
green   = "#b9f27c"
yellow  = "#ff9e64"
blue    = "#7da6ff"
magenta = "${PURPLE_HEX}"
cyan    = "${CYAN_HEX}"
white   = "#acb0d0"
